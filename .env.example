# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=        # service role key — bypasses RLS (never use anon key here)

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=                        # min 32 characters
ENCRYPTION_KEY=                    # min 32 characters — used for AES-256-CBC Gmail token encryption

# ── Gmail OAuth ───────────────────────────────────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=                # e.g. https://your-backend.railway.app/auth/gmail/callback

# ── Alert delivery — Gmail SMTP (last-resort fallback) ────────────────────────
GMAIL_USER=                        # Gmail address used as SMTP sender
GMAIL_APP_PASSWORD=                # Gmail app-specific password (not your account password)
ALERT_EMAIL=                       # destination address for email alerts

# ── Alert delivery — WhatsApp Business Cloud API (primary) ────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── Alert delivery — Vonage SMS (fallback) ────────────────────────────────────
VONAGE_API_KEY=
VONAGE_API_SECRET=

# ── External services ─────────────────────────────────────────────────────────
VIRUSTOTAL_API_KEY=
PYTHON_SERVICE_URL=                # e.g. https://your-python-service.railway.app
PYTHON_API_KEY=                    # shared secret between backend and Python service

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=                      # e.g. https://your-frontend.vercel.app
ALLOWED_ORIGINS=                   # comma-separated; defaults to FRONTEND_URL if blank
PORT=3000
NODE_ENV=development
